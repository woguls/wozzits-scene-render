    namespace
{
    using namespace wz::scene;

    inline void dfs_build_update_list(
        const TransformNode* nodes,
        uint32_t node,
        uint32_t* out_list,
        uint32_t& out_count
    )
    {
        const TransformNode& n = nodes[node];

        // Emit only animated nodes
        if (n.motion_type == TransformNode::MotionType::Animated)
        {
            out_list[out_count++] = node;
        }

        // Traverse children regardless (ordering matters)
        uint32_t child = n.first_child;
        while (child != TransformNode::INVALID_NODE)
        {
            dfs_build_update_list(nodes, child, out_list, out_count);
            child = nodes[child].next_sibling;
        }
    }

